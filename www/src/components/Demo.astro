---
import GradientButton from "./GradientButton.astro";
---

<section class="flex flex-col items-center gap-12 mb-52 px-4">
  <GradientButton id="showCanvas">Click here to start Demo</GradientButton>
  <div class="w-full flex justify-center overflow-x-auto">
    <div
      id="canvas-wrapper"
      class="hidden flex-col rounded-xl overflow-hidden bg-dark w-fit shadow-[0_0_0_1px_rgba(206,66,43,0.15),0_0_60px_rgba(206,66,43,0.08),0_40px_120px_rgba(0,0,0,0.7)]"
    >
      <!-- Terminal toolbar -->
      <div class="flex items-center justify-between px-4 py-2.5 bg-secondary border-b border-primary/10 select-none">
        <!-- Dots -->
        <div class="flex items-center gap-1.5">
          <span id="closeCanvas" class="w-2.5 h-2.5 rounded-full bg-primary shadow-[0_0_6px_rgba(206,55,43,0.5)]"
          ></span>
          <span class="w-2.5 h-2.5 rounded-full bg-[#4a4a2a]"></span>
          <span class="w-2.5 h-2.5 rounded-full bg-[#1a3a1a]"></span>
        </div>
        <!-- Title -->
        <div class="flex items-center gap-0.5 font-mono text-xs tracking-widest">
          <span class="text-primary font-bold">FERRUM</span>
          <span class="mx-0.5 text-primary/40">::</span>
          <span class="text-light/60">RENDER_ENGINE</span>
          <span class="text-primary animate-[blink_1.2s_step-end_infinite] ml-0.5">▋</span>
        </div>
        <!-- Badges -->
        <div class="flex gap-1.5">
          <span
            class="font-mono text-[10px] tracking-widest text-primary/70 border border-primary/20 rounded px-1.5 py-px"
            >WGPU</span
          >
          <span
            class="font-mono text-[10px] tracking-widest text-primary/70 border border-primary/20 rounded px-1.5 py-px"
            >WASM</span
          >
        </div>
      </div>
      <!-- Canvas Área -->
      <div class="relative leading-none">
        <canvas id="canvas" width="1280" height="720" class="block w-full h-auto aspect-video outline-none"></canvas>
        <!-- Vignete -->
        <div
          class="absolute inset-0 pointer-events-none bg-[radial-gradient(ellipse_at_center,transparent_55%,rgba(8,13,24,0.65)_100%)]"
        >
        </div>
      </div>
      <!-- Footer -->
      <div class="flex items-center gap-3 px-4 py-2 bg-secondary border-t border-primary/[0.08]">
        <div class="flex-1 h-px bg-gradient-to-r from-transparent via-primary/20 to-transparent"></div>
        <span class="font-mono text-[10px] tracking-[0.12em] text-primary/35 whitespace-nowrap"
          >ferrum v0.1.0-alpha</span
        >
        <div class="flex-1 h-px bg-gradient-to-r from-transparent via-primary/20 to-transparent"></div>
      </div>
    </div>
  </div>
</section>

<script type="module">
  const canvas = document.getElementById("showCanvas");
  canvas.addEventListener("click", async () => {
    const wrapper = document.getElementById("canvas-wrapper");

    wrapper.classList.remove("hidden");
    wrapper.classList.add("flex");
    wrapper.style.opacity = "0";
    wrapper.style.transform = "translateY(16px)";

    requestAnimationFrame(() => {
      wrapper.style.transition = "opacity 0.6s ease, transform 0.6s ease";
      wrapper.style.opacity = "1";
      wrapper.style.transform = "translateY(0)";
    });

    await new Promise((r) => wrapper.addEventListener("transitionend", r, { once: true }));

    const { default: init, run_web } = await import("/pkg/ferrum.js");
    await init();
    run_web();
  });

  const closeButton = document.getElementById("closeCanvas");
  closeButton.addEventListener("click", () => {
    const wrapper = document.getElementById("canvas-wrapper");
    wrapper.style.transition = "opacity 0.6s ease, transform 0.6s ease";
    wrapper.style.opacity = "0";
    wrapper.style.transform = "translateY(16px)";

    wrapper.addEventListener(
      "transitionend",
      () => {
        wrapper.classList.remove("flex");
        wrapper.classList.add("hidden");
        wrapper.style.opacity = "";
        wrapper.style.transform = "";
        wrapper.style.transition = "";
      },
      { once: true },
    );
  });
</script>

<style>
  @keyframes blink {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0;
    }
  }
</style>
