---
import GradientButton from "./GradientButton.astro";
---

<section class="mb-52 flex flex-col items-center gap-12 px-4">
  <GradientButton id="showCanvas">Click here to start Demo</GradientButton>
  <div class="flex w-full justify-center overflow-x-auto">
    <div
      id="canvas-wrapper"
      class="bg-dark hidden w-fit flex-col overflow-hidden rounded-xl shadow-[0_0_0_1px_rgba(206,66,43,0.15),0_0_60px_rgba(206,66,43,0.08),0_40px_120px_rgba(0,0,0,0.7)]"
    >
      <!-- Terminal toolbar -->
      <div
        class="bg-secondary border-primary/10 flex items-center justify-between border-b px-4 py-2.5 select-none"
      >
        <!-- Dots -->
        <div class="flex items-center gap-1.5">
          <span
            id="closeCanvas"
            class="bg-primary h-2.5 w-2.5 rounded-full shadow-[0_0_6px_rgba(206,55,43,0.5)]"
          ></span>
          <span class="h-2.5 w-2.5 rounded-full bg-[#4a4a2a]"></span>
          <span class="h-2.5 w-2.5 rounded-full bg-[#1a3a1a]"></span>
        </div>
        <!-- Title -->
        <div
          class="flex items-center gap-0.5 font-mono text-xs tracking-widest"
        >
          <span class="text-primary font-bold">FERRUM</span>
          <span class="text-primary/40 mx-0.5">::</span>
          <span class="text-light/60">RENDER_ENGINE</span>
          <span
            class="text-primary ml-0.5 animate-[blink_1.2s_step-end_infinite]"
            >▋</span
          >
        </div>
        <!-- Badges -->
        <div class="flex gap-1.5">
          <span
            class="text-primary/70 border-primary/20 rounded border px-1.5 py-px font-mono text-[10px] tracking-widest"
            >WGPU</span
          >
          <span
            class="text-primary/70 border-primary/20 rounded border px-1.5 py-px font-mono text-[10px] tracking-widest"
            >WASM</span
          >
        </div>
      </div>
      <!-- Canvas Área -->
      <div class="relative leading-none">
        <canvas
          id="canvas"
          width="1280"
          height="720"
          class="block aspect-video h-auto w-full outline-none"></canvas>
        <!-- Vignete -->
        <div
          class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_at_center,transparent_55%,rgba(8,13,24,0.65)_100%)]"
        >
        </div>
      </div>
      <!-- Footer -->
      <div
        class="bg-secondary border-primary/[0.08] flex items-center gap-3 border-t px-4 py-2"
      >
        <div
          class="via-primary/20 h-px flex-1 bg-gradient-to-r from-transparent to-transparent"
        >
        </div>
        <span
          class="text-primary/35 font-mono text-[10px] tracking-[0.12em] whitespace-nowrap"
          >ferrum v0.1.0-alpha</span
        >
        <div
          class="via-primary/20 h-px flex-1 bg-gradient-to-r from-transparent to-transparent"
        >
        </div>
      </div>
    </div>
  </div>
</section>

<script type="module">
  const canvas = document.getElementById("showCanvas");
  canvas.addEventListener("click", async () => {
    const wrapper = document.getElementById("canvas-wrapper");

    wrapper.classList.remove("hidden");
    wrapper.classList.add("flex");
    wrapper.style.opacity = "0";
    wrapper.style.transform = "translateY(16px)";

    requestAnimationFrame(() => {
      wrapper.style.transition = "opacity 0.6s ease, transform 0.6s ease";
      wrapper.style.opacity = "1";
      wrapper.style.transform = "translateY(0)";
    });

    await new Promise((r) =>
      wrapper.addEventListener("transitionend", r, { once: true }),
    );

    const { default: init, run_web } = await import("/pkg/ferrum.js");
    await init();
    run_web();
  });

  const closeButton = document.getElementById("closeCanvas");
  closeButton.addEventListener("click", () => {
    const wrapper = document.getElementById("canvas-wrapper");
    wrapper.style.transition = "opacity 0.6s ease, transform 0.6s ease";
    wrapper.style.opacity = "0";
    wrapper.style.transform = "translateY(16px)";

    wrapper.addEventListener(
      "transitionend",
      () => {
        wrapper.classList.remove("flex");
        wrapper.classList.add("hidden");
        wrapper.style.opacity = "";
        wrapper.style.transform = "";
        wrapper.style.transition = "";
      },
      { once: true },
    );
  });
</script>

<style>
  @keyframes blink {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0;
    }
  }
</style>
