---
import FerrumLogo from "@/assets/icons/FerrumLogo.astro";
import GitHubIcon from "@/assets/icons/GitHubIcon.astro";
---

<header
  class="bg-secondary/90 sticky top-0 z-50 border-1 border-b border-gray-700 opacity-95"
>
  <!-- Main row: always visible -->
  <div class="flex items-center justify-between p-4 lg:px-20">
    <a href="/" class="flex-shrink-0 cursor-pointer">
      <FerrumLogo height="80" width="80" />
    </a>

    <!-- Desktop nav — hidden on mobile -->
    <nav class="hidden md:block">
      <ul
        class="text-md flex cursor-pointer space-x-5 lg:space-x-10 lg:text-xl"
      >
        <li
          class="hover:text-primary-light group text-md relative transition-all duration-200"
        >
          <a href="/">
            Home
            <span
              class="from-accent to-primary-light absolute bottom-0 left-0 h-0.5 w-0 bg-linear-to-r transition-all duration-200 group-hover:w-full"
            ></span>
          </a>
        </li>
        <li
          class="hover:text-primary-light group text-md relative transition-all duration-200"
        >
          <a href="/#features">
            Features
            <span
              class="from-accent to-primary-light absolute bottom-0 left-0 h-0.5 w-0 bg-linear-to-r transition-all duration-200 group-hover:w-full"
            ></span>
          </a>
        </li>
        <li
          class="hover:text-primary-light group text-md relative transition-all duration-200"
        >
          <a href="/#vr">
            VR
            <span
              class="from-accent to-primary-light absolute bottom-0 left-0 h-0.5 w-0 bg-linear-to-r transition-all duration-200 group-hover:w-full"
            ></span>
          </a>
        </li>
        <li
          class="hover:text-primary-light group text-md relative transition-all duration-200"
        >
          <a href="/#requirements">
            Requirments
            <span
              class="from-accent to-primary-light absolute bottom-0 left-0 h-0.5 w-0 bg-linear-to-r transition-all duration-200 group-hover:w-full"
            ></span>
          </a>
        </li>
        <li
          class="hover:text-primary-light group text-md relative transition-all duration-200"
        >
          <a href="/demo">
            Demo
            <span
              class="from-accent to-primary-light absolute bottom-0 left-0 h-0.5 w-0 bg-linear-to-r transition-all duration-200 group-hover:w-full"
            ></span>
          </a>
        </li>
        <li
          class="hover:text-primary-light group text-md relative transition-all duration-200"
        >
          <a href="/download">
            Download
            <span
              class="from-accent to-primary-light absolute bottom-0 left-0 h-0.5 w-0 bg-linear-to-r transition-all duration-200 group-hover:w-full"
            ></span>
          </a>
        </li>
        <li
          class="hover:text-primary-light group text-md relative transition-all duration-200"
        >
          <a href="/contact">
            Contacto
            <span
              class="from-accent to-primary-light absolute bottom-0 left-0 h-0.5 w-0 bg-linear-to-r transition-all duration-200 group-hover:w-full"
            ></span>
          </a>
        </li>
      </ul>
    </nav>

    <!-- Right: GitHub + hamburger -->
    <div class="flex flex-shrink-0 items-center gap-3">
      <a
        href="https://github.com/karlosvas"
        target="_blank"
        class="hover:text-primary-light cursor-pointer transition-all duration-200"
      >
        <GitHubIcon height="30" width="30" />
      </a>

      <!-- Hamburger button — visible only on mobile -->
      <button
        id="menu-toggle"
        class="md:hidden cursor-pointer rounded p-1.5 transition-colors duration-200 hover:bg-white/10"
        aria-label="Abrir menú de navegación"
        aria-expanded="false"
      >
        <span
          class="block h-0.5 w-5 bg-current transition-all duration-300"
          id="bar1"></span>
        <span
          class="my-1 block h-0.5 w-5 bg-current transition-all duration-300"
          id="bar2"></span>
        <span
          class="block h-0.5 w-5 bg-current transition-all duration-300"
          id="bar3"></span>
      </button>
    </div>
  </div>

  <!-- Mobile nav dropdown — hidden by default, always hidden on md+ -->
  <nav
    id="mobile-menu"
    class="hidden border-t border-gray-700 md:hidden"
    aria-hidden="true"
  >
    <ul class="flex flex-col space-y-1 p-4 text-base">
      <li>
        <a
          href="/"
          class="hover:text-primary-light hover:bg-white/5 block rounded-lg px-3 py-2 transition-all duration-200"
          >Home</a
        >
      </li>
      <li>
        <a
          href="/#features"
          class="hover:text-primary-light hover:bg-white/5 block rounded-lg px-3 py-2 transition-all duration-200"
          >Features</a
        >
      </li>
      <li>
        <a
          href="/#vr"
          class="hover:text-primary-light hover:bg-white/5 block rounded-lg px-3 py-2 transition-all duration-200"
          >VR</a
        >
      </li>
      <li>
        <a
          href="/#requirements"
          class="hover:text-primary-light hover:bg-white/5 block rounded-lg px-3 py-2 transition-all duration-200"
          >Requirments</a
        >
      </li>
      <li>
        <a
          href="/demo"
          class="hover:text-primary-light hover:bg-white/5 block rounded-lg px-3 py-2 transition-all duration-200"
          >Demo</a
        >
      </li>
      <li>
        <a
          href="/download"
          class="hover:text-primary-light hover:bg-white/5 block rounded-lg px-3 py-2 transition-all duration-200"
          >Download</a
        >
      </li>
    </ul>
  </nav>
</header>

<script>
  const toggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");
  const bar1 = document.getElementById("bar1");
  const bar2 = document.getElementById("bar2");
  const bar3 = document.getElementById("bar3");

  toggle?.addEventListener("click", () => {
    const isOpen = !menu?.classList.contains("hidden");

    // Toggle menu visibility
    menu?.classList.toggle("hidden", isOpen);
    menu?.setAttribute("aria-hidden", String(isOpen));
    toggle.setAttribute("aria-expanded", String(!isOpen));

    // Animate hamburger → X
    if (!isOpen) {
      bar1?.classList.add("translate-y-1.5", "rotate-45");
      bar2?.classList.add("opacity-0", "scale-x-0");
      bar3?.classList.add("-translate-y-1.5", "-rotate-45");
    } else {
      bar1?.classList.remove("translate-y-1.5", "rotate-45");
      bar2?.classList.remove("opacity-0", "scale-x-0");
      bar3?.classList.remove("-translate-y-1.5", "-rotate-45");
    }
  });

  // Close mobile menu when a nav link is clicked
  menu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      menu.classList.add("hidden");
      menu.setAttribute("aria-hidden", "true");
      toggle?.setAttribute("aria-expanded", "false");
      bar1?.classList.remove("translate-y-1.5", "rotate-45");
      bar2?.classList.remove("opacity-0", "scale-x-0");
      bar3?.classList.remove("-translate-y-1.5", "-rotate-45");
    });
  });
</script>
