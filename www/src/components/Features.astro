---
interface Props {
  dataSection: Array<Record<string, any>>;
}
const { dataSection } = Astro.props;
---

<section class="my-52">
  <h2 class="text-primary-light mt-80 font-bold text-2xl">Características</h2>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 my-5">
    {
      dataSection.map((item) => {
        return (
          <div class="bg-secondary/60 border-primary-light border-1 p-3 space-y-3 rounded-xl hover:translate-y-0.5 transition-transform duration-200 hover:bg-secondary/40 transition-colors group">
            <span class="flex space-x-3 items-center">
              <item.svg heigth="30px" width="40px" class="group-hover:text-primary" />
              <h3 class="text-shadow-white group-hover:text-primary-light">{item.title}</h3>
            </span>
            <p class="text-muted group-hover:text-white transition-colors duration-200">{item.description}</p>
          </div>
        );
      })
    }
  </div>
</section>
