---
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Layout from "../layouts/Layout.astro";
import HeroSection from "@/components/HeroSection.astro";
import BoxIcon from "@/assets/icons/BoxIcon.astro";
import GlassesIcon from "@/assets/icons/GlassesIcon.astro";
import GlobeIcon from "@/assets/icons/GlobeIcon.astro";
import LayersIcon from "@/assets/icons/LayersIcon.astro";
import MonitorIcon from "@/assets/icons/MonitorIcon.astro";
import ZapIcon from "@/assets/icons/ZapIcon.astro";
import Features from "@/components/Features.astro";
import GradientEffect from "@/components/GradientEffect.astro";
import Requierments from "@/components/Requierments.astro";
import Download from "@/components/Download.astro";
import VirtualReality from "@/components/VirtualReality.astro";

const dataSection = [
  {
    title:
      "Arquitectura Técnica para Visualización Multiescala Vegetal",
    description:
      "Ferrum combina rendering PBR (Physically Based Rendering) con precisión botánica para generar una experiencia de aprendizaje que reproduce la complejidad estructural que estudian biólogos e investigadores.",
    svg: BoxIcon,
  },
  {
    title: "Experiencia Inmersiva de Realidad Virtual",
    description:
      "Sumérgete en un entorno tridimensional interactivo que facilita la comprensión espacial de estructuras vegetales complejas, desde raíces hasta cloroplastos.",
    svg: GlassesIcon,
  },
  {
    title: "Modelos Botánicos Científicamente Validados",
    description:
      "Accede a representaciones precisas y detalladas de plantas, tejidos y organelas, desarrolladas con rigor científico para uso educativo.",
    svg: GlobeIcon,
  },
  {
    title: "Multiplataforma y Accesible",
    description:
      "Disponible en Windows, macOS y Linux, con una versión WebAssembly para acceso sin instalación.",
    svg: LayersIcon,
  },
  {
    title: "Navegación Continua entre Escalas Biológicas",
    description:
      "Explora desde la morfología externa de una planta hasta sus estructuras celulares y moleculares con transiciones fluidas e ininterrumpidas.",
    svg: MonitorIcon,
  },
  {
    title: "Rendering en Tiempo Real Optimizado",
    description:
      "Disfruta de una experiencia visual fluida con un motor gráfico construido en Rust y wgpu, garantizando 60 FPS.",
    svg: ZapIcon,
  },
];
---

<Layout>
  <Header />
  <main class="m-auto mt-20 h-fit w-[92%] max-w-[1400px] px-4 sm:px-8 md:px-16 lg:w-[75%] xl:w-[70%]">
    <GradientEffect />
    <HeroSection />
    <Features dataSection={dataSection} />
    <VirtualReality />
    <Download />
    <Requierments />
  </main>
  <Footer />
</Layout>
