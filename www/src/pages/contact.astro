---
import Footer from "@/components/Footer.astro";
import Header from "@/components/Header.astro";
import Layout from "@/layouts/Layout.astro";
---

<Layout>
  <Header />
  <main class="relative py-20">
  <!-- Glow effect -->
  <div class="pointer-events-none absolute inset-0 -z-10 overflow-hidden">
    <div
      class="bg-primary absolute top-1/2 left-1/2 h-[500px] w-[500px] -translate-x-1/2 -translate-y-1/2 rounded-full opacity-10 blur-[120px]"
    >
    </div>
  </div>

  <div class="mx-auto max-w-2xl">
    <!-- Header -->
    <div class="mb-12 text-center">
      <span
        class="bg-primary/10 border-primary/20 text-primary-light mb-4 inline-block rounded-full border px-4 py-1.5 text-sm font-medium"
        >Contacto</span
      >
      <h2 class="text-3xl font-bold text-white sm:text-4xl">
        ¿Tienes alguna pregunta?
      </h2>
      <p class="text-muted mt-4 text-base leading-relaxed">
        Envíanos un mensaje y te responderemos lo antes posible.
      </p>
    </div>

    <!-- Card -->
    <div
      class="bg-secondary/60 relative rounded-2xl border border-white/5 p-8 shadow-2xl backdrop-blur-sm"
    >
      <!-- Top accent line -->
      <div
        class="from-primary to-primary-light absolute inset-x-0 top-0 h-px rounded-t-2xl bg-gradient-to-r opacity-60"
      >
      </div>

      <form id="contact-form" class="flex flex-col gap-6">
        <!-- Name + Email row -->
        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
          <div class="flex flex-col gap-2">
            <label for="name" class="text-light text-sm font-medium"
              >Nombre</label
            >
            <input
              id="name"
              name="name"
              type="text"
              required
              placeholder="Tu nombre"
              class="bg-dark/60 border-white/10 text-light placeholder:text-muted focus:border-primary focus:ring-primary/20 rounded-xl border px-4 py-3 text-sm outline-none transition-all duration-200 focus:ring-2"
            />
          </div>
          <div class="flex flex-col gap-2">
            <label for="email" class="text-light text-sm font-medium"
              >Email</label
            >
            <input
              id="email"
              name="email"
              type="email"
              required
              placeholder="tu@email.com"
              class="bg-dark/60 border-white/10 text-light placeholder:text-muted focus:border-primary focus:ring-primary/20 rounded-xl border px-4 py-3 text-sm outline-none transition-all duration-200 focus:ring-2"
            />
          </div>
        </div>

        <!-- Subject -->
        <div class="flex flex-col gap-2">
          <label for="subject" class="text-light text-sm font-medium"
            >Asunto</label
          >
          <input
            id="subject"
            name="subject"
            type="text"
            required
            placeholder="¿En qué podemos ayudarte?"
            class="bg-dark/60 border-white/10 text-light placeholder:text-muted focus:border-primary focus:ring-primary/20 rounded-xl border px-4 py-3 text-sm outline-none transition-all duration-200 focus:ring-2"
          />
        </div>

        <!-- Message -->
        <div class="flex flex-col gap-2">
          <label for="message" class="text-light text-sm font-medium"
            >Mensaje</label
          >
          <textarea
            id="message"
            name="message"
            required
            rows="5"
            placeholder="Escribe tu mensaje aquí..."
            class="bg-dark/60 border-white/10 text-light placeholder:text-muted focus:border-primary focus:ring-primary/20 resize-none rounded-xl border px-4 py-3 text-sm outline-none transition-all duration-200 focus:ring-2"
          ></textarea>
        </div>

        <!-- Submit -->
        <button
          id="submit-btn"
          type="submit"
          class="from-primary to-primary-light relative mt-2 flex w-full cursor-pointer items-center justify-center gap-2 rounded-xl bg-gradient-to-r py-3.5 text-sm font-semibold text-white transition-all duration-200 hover:translate-y-[-1px] hover:opacity-90 active:translate-y-0 disabled:cursor-not-allowed disabled:opacity-60"
        >
          <!-- Glow under button -->
          <div class="absolute inset-0 bottom-[-16px] -z-10 opacity-30">
            <div
              class="bg-primary absolute bottom-0 left-0 h-16 w-full rounded-full blur-[20px]"
            >
            </div>
          </div>

          <span id="btn-text">Enviar mensaje</span>
          <svg
            id="btn-spinner"
            class="hidden h-4 w-4 animate-spin"
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
          >
            <circle
              class="opacity-25"
              cx="12"
              cy="12"
              r="10"
              stroke="currentColor"
              stroke-width="4"></circle>
            <path
              class="opacity-75"
              fill="currentColor"
              d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
          </svg>
        </button>
      </form>
    </div>

    <!-- Footer note -->
    <p class="text-muted mt-6 text-center text-xs">
      También puedes encontrarnos en
      <a
        href="https://github.com/karlosvas/ferrum"
        class="text-primary-light hover:underline">GitHub</a
      >.
    </p>
  </div>
</main>

<script>
  declare const Toastify: (opts: object) => { showToast: () => void };

  const form = document.getElementById("contact-form") as HTMLFormElement;
  const btn = document.getElementById("submit-btn") as HTMLButtonElement;
  const btnText = document.getElementById("btn-text") as HTMLSpanElement;
  const spinner = document.getElementById("btn-spinner") as HTMLElement;

  function setLoading(loading: boolean) {
    btn.disabled = loading;
    btnText.textContent = loading ? "Enviando..." : "Enviar mensaje";
    spinner.classList.toggle("hidden", !loading);
  }

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    setLoading(true);

    const data = Object.fromEntries(new FormData(form));

    try {
      const res = await fetch("/resend", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(data),
      });

      const json = await res.json();

      if (res.ok) {
        Toastify({
          text: "✓ Mensaje enviado correctamente",
          duration: 4000,
          gravity: "bottom",
          position: "right",
          style: {
            background: "linear-gradient(to right, #ce422b, #e85a3f)",
            borderRadius: "12px",
            fontSize: "14px",
            fontWeight: "600",
          },
        }).showToast();
        form.reset();
      } else {
        throw new Error(json.error ?? "Error al enviar");
      }
    } catch (err) {
      Toastify({
        text: "✗ Error al enviar el mensaje. Inténtalo de nuevo.",
        duration: 4000,
        gravity: "bottom",
        position: "right",
        style: {
          background: "linear-gradient(to right, #7f1d1d, #ce422b)",
          borderRadius: "12px",
          fontSize: "14px",
          fontWeight: "600",
        },
      }).showToast();
    } finally {
      setLoading(false);
    }
  });
</script>

  <Footer />
</Layout>